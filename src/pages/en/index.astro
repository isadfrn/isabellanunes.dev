---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getTranslations } from '@/i18n';
import { getNavItems } from '@/i18n/utils';

const locale = 'en';
const t = getTranslations(locale);
const navItems = getNavItems(locale);
const currentPath = Astro.url.pathname;
---
<BaseLayout title={t.nav.home} locale={locale} currentPath={currentPath}>
  <section class="container" style="flex: 1; display: flex; flex-direction: column; justify-content: center; min-height: 100vh; padding-block: var(--space-16);">
    <div>
      <p style="font-size: var(--font-size-base); color: var(--color-text-muted); margin-bottom: var(--space-2);">
        {t.home.greeting}
      </p>
      <h1 style="font-size: var(--font-size-4xl); font-weight: var(--font-weight-bold); margin-bottom: var(--space-4); line-height: 1.2;">
        Isabella Nunes
      </h1>
      <p style="font-size: var(--font-size-xl); color: var(--color-text-muted); margin-bottom: var(--space-6);">
        {t.home.subtitle}
      </p>
      <p style="font-size: var(--font-size-base); max-width: 42rem; margin-bottom: var(--space-8); line-height: 1.7;">
        {t.home.description}
      </p>
      <p style="font-size: var(--font-size-base); margin-bottom: var(--space-8);">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: var(--space-3);">
        {navItems.filter((item) => item.key !== 'home').map((item) => (
          <a
            href={item.href}
            style={{
              display: 'inline-block',
              padding: 'var(--space-2) var(--space-4)',
              background: 'var(--color-accent)',
              color: 'var(--color-accent-foreground)',
              borderRadius: '0.5rem',
              fontWeight: 'var(--font-weight-medium)',
              transition: 'background-color var(--transition-fast)',
            }}
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
