---
import PostLayout from '@layouts/PostLayout.astro';
import { getCollection, render } from 'astro:content';
import { getTranslations } from '@/i18n';
import { formatDate } from '@/i18n/utils';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  return allPosts
    .filter((post) => post.data.locale === 'en')
    .map((post) => {
      const parts = post.id.split('/');
      const slug = parts[parts.length - 1] ?? post.id;
      return {
        params: { slug },
        props: { post },
      };
    });
}

const locale = 'en' as const;
const t = getTranslations(locale);
const { post } = Astro.props;
const { Content } = await render(post);
const currentPath = Astro.url.pathname;

const breadcrumbItems = [
  { href: `/${locale}`, label: t.breadcrumb.home },
  { href: `/${locale}/blog`, label: t.breadcrumb.blog },
  { href: `/${locale}/blog/${Astro.params.slug}`, label: post.data.title },
];
---
<PostLayout title={post.data.title} locale={locale} currentPath={currentPath} breadcrumbItems={breadcrumbItems}>
  <article class="container" style="flex: 1; padding-block: var(--space-8) var(--space-16); min-height: 100vh;">
    <header style="margin-bottom: var(--space-8);">
      <h1 style="font-size: var(--font-size-3xl); font-weight: var(--font-weight-bold); margin-bottom: var(--space-4);">
        {post.data.title}
      </h1>
      <p style="font-size: var(--font-size-sm); color: var(--color-text-muted); margin-bottom: var(--space-3);">
        {t.common.postedOn} {formatDate(post.data.pubDate, locale)}
      </p>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="card-tags">
          {post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</PostLayout>
