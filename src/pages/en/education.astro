---
import BaseLayout from '@layouts/BaseLayout.astro';
import Timeline from '@components/Timeline';
import { getTranslations } from '@/i18n';
import educationData from '@/data/education/en';

const locale = 'en';
const t = getTranslations(locale);
const currentPath = Astro.url.pathname;
---
<BaseLayout title={t.education.title} locale={locale} currentPath={currentPath}>
  <article class="container" style="flex: 1; padding-block: var(--space-16); min-height: 100vh;">
    <h1 style="font-size: var(--font-size-3xl); font-weight: var(--font-weight-bold); margin-bottom: var(--space-2);">
      {t.education.title}
    </h1>
    <p style="font-size: var(--font-size-base); color: var(--color-text-muted); margin-bottom: var(--space-10);">
      {t.education.subtitle}
    </p>
    <Timeline entries={educationData} />
  </article>
</BaseLayout>
