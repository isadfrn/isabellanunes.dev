---
import PostLayout from '@layouts/PostLayout.astro';
import { getTranslations } from '@/i18n';
import { getNavItems } from '@/i18n/utils';
import { locales } from '@/types';
import type { Locale } from '@/types';
import projectsData from '@/data/projects';

export function getStaticPaths() {
  return locales.flatMap((locale) =>
    projectsData[locale].map((project) => ({
      params: { locale, slug: project.slug },
      props: { project },
    }))
  );
}

const locale = Astro.params.locale as Locale;
const t = getTranslations(locale);
const navItems = getNavItems(locale);
const { project } = Astro.props;
const currentPath = Astro.url.pathname;

const breadcrumbItems = [
  { href: `/${locale}`, label: t.breadcrumb.home },
  { href: `/${locale}/projects`, label: t.breadcrumb.projects },
  { href: currentPath, label: project.title },
];
---
<PostLayout
  title={project.title}
  description={project.description}
  locale={locale}
  currentPath={currentPath}
  breadcrumbItems={breadcrumbItems}
  navItems={navItems}
>
  <article class="container flex-1 py-8 pb-20 lg:pl-0 pl-16 md:pl-8 min-h-screen page-enter">
    <div class="max-w-2xl">
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-slate-50 mb-4">
        {project.title}
      </h1>
      <p class="text-lg text-slate-500 dark:text-slate-400 mb-6 leading-relaxed">
        {project.description}
      </p>

      <div class="flex flex-wrap gap-1.5 mb-6">
        {project.tags.map((tag: string) => (
          <span class="inline-block px-2 py-0.5 text-xs font-medium bg-primary-50 dark:bg-primary-900/40 text-primary-700 dark:text-primary-300 rounded-full">
            {tag}
          </span>
        ))}
      </div>

      <div class="flex flex-wrap gap-4 mb-10">
        {project.url && (
          <a
            href={project.url}
            class="inline-flex items-center gap-1.5 px-4 py-2 bg-primary-500 hover:bg-primary-600 text-white rounded-lg text-sm font-medium transition-colors duration-150"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t.projects.view_project} →
          </a>
        )}
        {project.repo && (
          <a
            href={project.repo}
            class="inline-flex items-center gap-1.5 px-4 py-2 border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg text-sm font-medium transition-colors duration-150"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t.projects.repository} →
          </a>
        )}
      </div>

      <p class="text-base text-slate-600 dark:text-slate-300 leading-relaxed mb-4">
        {t.projects.content_placeholder_1}
      </p>
      <p class="text-base text-slate-600 dark:text-slate-300 leading-relaxed mb-4">
        {t.projects.content_placeholder_2}
      </p>
      <p class="text-base text-slate-600 dark:text-slate-300 leading-relaxed">
        {t.projects.content_placeholder_3}
      </p>
    </div>
  </article>
</PostLayout>
