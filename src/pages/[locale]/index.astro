---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getNavItems } from '@/i18n/utils';
import { locales } from '@/types';
import type { Locale } from '@/types';
import homeData from '@/data/home';
import aboutData from '@/data/about';

export const prerender = true;

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const navItems = getNavItems(locale);
const currentPath = Astro.url.pathname;
const home = homeData[locale];
const about = aboutData[locale];
---
<BaseLayout
  title="Isabella Nunes"
  description={about.description}
  locale={locale}
  currentPath={currentPath}
  navItems={navItems}
>
  <section class="container flex-1 py-20 lg:pl-0 pl-16 md:pl-8 min-h-screen page-enter">
    <div class="max-w-2xl page-enter-slide">
      <p class="text-sm font-medium text-primary-600 dark:text-primary-400 mb-3 tracking-wide uppercase">
        {home.greeting}
      </p>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-slate-50 mb-4 leading-tight">
        Isabella Nunes
      </h1>
      <p class="text-xl text-slate-500 dark:text-slate-400 mb-6 leading-relaxed">
        {home.subtitle}
      </p>
      <p class="text-base text-slate-600 dark:text-slate-300 mb-4 leading-relaxed">
        {home.description}
      </p>
      <p class="text-base text-slate-600 dark:text-slate-300 leading-relaxed">
        {home.extra}
      </p>
    </div>
  </section>
</BaseLayout>
