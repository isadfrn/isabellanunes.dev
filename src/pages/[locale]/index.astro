---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getTranslations } from '@/i18n';
import { getNavItems } from '@/i18n/utils';
import { locales } from '@/types';
import type { Locale } from '@/types';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = getTranslations(locale);
const navItems = getNavItems(locale);
const currentPath = Astro.url.pathname;
---
<BaseLayout
  title={t.nav.home}
  description={t.about.description}
  locale={locale}
  currentPath={currentPath}
  navItems={navItems}
>
  <section class="container flex flex-col justify-center flex-1 min-h-screen py-20 lg:pl-0 pl-16 md:pl-8">
    <div class="max-w-2xl page-enter-slide">
      <p class="text-sm font-medium text-primary-600 dark:text-primary-400 mb-3 tracking-wide uppercase">
        {t.home.greeting}
      </p>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-slate-50 mb-4 leading-tight">
        Isabella Nunes
      </h1>
      <p class="text-xl text-slate-500 dark:text-slate-400 mb-6 leading-relaxed">
        {t.home.subtitle}
      </p>
      <p class="text-base text-slate-600 dark:text-slate-300 mb-4 leading-relaxed">
        {t.home.description}
      </p>
      <p class="text-base text-slate-600 dark:text-slate-300 mb-10 leading-relaxed">
        {t.home.extra}
      </p>
      <div class="flex flex-wrap gap-3">
        {navItems.filter((item) => item.key !== 'home').map((item) => (
          <a
            href={item.href}
            class="inline-block px-4 py-2 bg-primary-500 hover:bg-primary-600 text-white rounded-lg text-sm font-medium transition-colors duration-150"
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
