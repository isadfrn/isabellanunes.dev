---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getNavItems } from '@/i18n/utils';
import { locales } from '@/types';
import type { Locale } from '@/types';
import aboutData from '@/data/about';

export const prerender = true;

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const navItems = getNavItems(locale);
const currentPath = Astro.url.pathname;
const about = aboutData[locale];
---
<BaseLayout
  title={about.title}
  description={about.description}
  locale={locale}
  currentPath={currentPath}
  navItems={navItems}
>
  <article class="container flex-1 py-20 lg:pl-0 pl-16 md:pl-8 min-h-screen page-enter">
    <div class="max-w-2xl">
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-slate-50 mb-6">
        {about.title}
      </h1>
      <p data-reveal class="text-lg text-slate-600 dark:text-slate-300 leading-relaxed mb-6">
        {about.intro}
      </p>
      <p data-reveal style="--reveal-delay:80ms" class="text-base text-slate-600 dark:text-slate-300 leading-relaxed mb-4">
        {about.bio_1}
      </p>
      <p data-reveal style="--reveal-delay:160ms" class="text-base text-slate-600 dark:text-slate-300 leading-relaxed mb-10">
        {about.bio_2}
      </p>
      <h2 data-reveal style="--reveal-delay:240ms" class="text-xl font-semibold text-slate-900 dark:text-slate-50 mb-4">
        {about.skills_title}
      </h2>
      <p data-reveal style="--reveal-delay:320ms" class="text-base text-slate-600 dark:text-slate-300 leading-relaxed">
        {about.skills_desc}
      </p>
    </div>
  </article>
</BaseLayout>
