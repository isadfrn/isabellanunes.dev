---
import PostLayout from '@layouts/PostLayout.astro';
import { getCollection, render } from 'astro:content';
import { getTranslations } from '@/i18n';
import { getNavItems, slugFromId, formatDate } from '@/i18n/utils';
import type { Locale } from '@/types';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  return allPosts.map((post) => ({
    params: { locale: post.data.locale, slug: slugFromId(post.id) },
    props: { post },
  }));
}

const locale = Astro.params.locale as Locale;
const t = getTranslations(locale);
const navItems = getNavItems(locale);
const { post } = Astro.props;
const { Content } = await render(post);
const currentPath = Astro.url.pathname;

const breadcrumbItems = [
  { href: `/${locale}`, label: t.breadcrumb.home },
  { href: `/${locale}/blog`, label: t.breadcrumb.blog },
  { href: currentPath, label: post.data.title },
];
---
<PostLayout
  title={post.data.title}
  description={post.data.description}
  locale={locale}
  currentPath={currentPath}
  breadcrumbItems={breadcrumbItems}
  navItems={navItems}
>
  <article class="container flex-1 py-8 pb-20 lg:pl-0 pl-16 md:pl-8 min-h-screen page-enter">
    <div class="max-w-2xl">
      <header class="mb-10">
        <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-slate-50 mb-4">
          {post.data.title}
        </h1>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">
          {t.common.postedOn} {formatDate(post.data.pubDate, locale)}
        </p>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {post.data.tags.map((tag: string) => (
              <span class="inline-block px-2 py-0.5 text-xs font-medium bg-primary-50 dark:bg-primary-900/40 text-primary-700 dark:text-primary-300 rounded-full">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</PostLayout>
