---
import BaseLayout from '@layouts/BaseLayout.astro';
import Card from '@components/Card';
import { getTranslations } from '@/i18n';
import { getNavItems } from '@/i18n/utils';
import { locales } from '@/types';
import type { Locale } from '@/types';
import blogData from '@/data/blog';

export const prerender = true;

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = getTranslations(locale);
const navItems = getNavItems(locale);
const currentPath = Astro.url.pathname;

const posts = blogData[locale].sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());
---
<BaseLayout
  title={t.blog.title}
  description={t.blog.description}
  locale={locale}
  currentPath={currentPath}
  navItems={navItems}
>
  <article class="container flex-1 py-20 lg:pl-0 pl-16 md:pl-8 min-h-screen page-enter">
    <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-slate-50 mb-2">
      {t.blog.title}
    </h1>
    <p class="text-base text-slate-500 dark:text-slate-400 mb-10">
      {t.blog.subtitle}
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post, index) => (
        <Card
          entry={{
            slug: post.slug,
            title: post.title,
            description: post.description,
            image: post.image ?? '/images/placeholder.jpg',
            tags: post.tags,
          }}
          href={`/${locale}/blog/${post.slug}`}
          readMoreLabel={t.common.readMore}
          revealDelay={index * 80}
        />
      ))}
    </div>
  </article>
</BaseLayout>
