---
import BaseLayout from '@layouts/BaseLayout.astro';
import Card from '@components/Card';
import { getCollection } from 'astro:content';
import { getTranslations } from '@/i18n';
import { getNavItems, slugFromId } from '@/i18n/utils';
import { locales } from '@/types';
import type { Locale } from '@/types';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = getTranslations(locale);
const navItems = getNavItems(locale);
const currentPath = Astro.url.pathname;

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => post.data.locale === locale)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout
  title={t.blog.title}
  description={t.blog.description}
  locale={locale}
  currentPath={currentPath}
  navItems={navItems}
>
  <article class="container flex-1 py-20 lg:pl-0 pl-16 md:pl-8 min-h-screen page-enter">
    <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-slate-50 mb-2">
      {t.blog.title}
    </h1>
    <p class="text-base text-slate-500 dark:text-slate-400 mb-10">
      {t.blog.subtitle}
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => {
        const slug = slugFromId(post.id);
        const cardEntry = {
          slug,
          title: post.data.title,
          description: post.data.description,
          image: post.data.image ?? '/images/placeholder.jpg',
          tags: post.data.tags,
        };
        return (
          <Card
            entry={cardEntry}
            href={`/${locale}/blog/${slug}`}
            readMoreLabel={t.common.readMore}
          />
        );
      })}
    </div>
  </article>
</BaseLayout>
