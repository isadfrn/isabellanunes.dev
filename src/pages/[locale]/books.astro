---
import BaseLayout from '@layouts/BaseLayout.astro';
import BookCard from '@components/BookCard';
import { getTranslations } from '@/i18n';
import { getNavItems } from '@/i18n/utils';
import { locales } from '@/types';
import type { Locale } from '@/types';
import books from '@/data/books';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = getTranslations(locale);
const navItems = getNavItems(locale);
const currentPath = Astro.url.pathname;
---
<BaseLayout
  title={t.books.title}
  description={t.books.description}
  locale={locale}
  currentPath={currentPath}
  navItems={navItems}
>
  <article class="container flex-1 py-20 lg:pl-0 pl-16 md:pl-8 min-h-screen page-enter">
    <div class="max-w-4xl">
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-slate-50 mb-2">
        {t.books.title}
      </h1>
      <p class="text-base text-slate-500 dark:text-slate-400 mb-10">
        {t.books.subtitle}
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {books.map((book, index) => (
          <BookCard
            entry={book}
            labels={{ buyBook: t.books.buyBook }}
            revealDelay={index * 80}
          />
        ))}
      </div>
    </div>
  </article>
</BaseLayout>
