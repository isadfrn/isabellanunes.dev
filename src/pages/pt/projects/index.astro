---
import BaseLayout from '@layouts/BaseLayout.astro';
import Card from '@components/Card';
import { getTranslations } from '@/i18n';
import projects from '@/data/projects/pt';

const locale = 'pt';
const t = getTranslations(locale);
const currentPath = Astro.url.pathname;
---
<BaseLayout title={t.projects.title} locale={locale} currentPath={currentPath}>
  <article class="container" style="flex: 1; padding-block: var(--space-16); min-height: 100vh;">
    <h1 style="font-size: var(--font-size-3xl); font-weight: var(--font-weight-bold); margin-bottom: var(--space-2);">
      {t.projects.title}
    </h1>
    <p style="font-size: var(--font-size-base); color: var(--color-text-muted); margin-bottom: var(--space-10);">
      {t.projects.subtitle}
    </p>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: var(--space-6);">
      {projects.map((project) => (
        <Card
          entry={project}
          href={`/${locale}/projects/${project.slug}`}
          readMoreLabel={t.common.readMore}
        />
      ))}
    </div>
  </article>
</BaseLayout>
