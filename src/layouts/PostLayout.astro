---
import ThemeProvider from '@components/ThemeProvider.astro';
import HamburgerMenu from '@components/HamburgerMenu';
import Breadcrumb from '@components/Breadcrumb';
import { ViewTransitions } from 'astro:transitions';
import '@styles/global.css';
import { getTranslations, getAlternateLocale } from '@/i18n';
import { getNavItems } from '@/i18n/utils';
import aboutData from '@/data/about';
import type { NavItem } from '@/types';

interface BreadcrumbItem {
  href: string;
  label: string;
}

interface Props {
  title: string;
  description?: string;
  locale: string;
  currentPath?: string;
  breadcrumbItems: BreadcrumbItem[];
  navItems?: NavItem[];
}

const { title, description, locale, currentPath = '', breadcrumbItems, navItems: navItemsProp } = Astro.props;
const t = getTranslations(locale);
const altLocale = getAlternateLocale(locale);
const navItems = navItemsProp ?? getNavItems(locale);
const pageDescription = description ?? aboutData[locale as 'pt' | 'en'].description;
const canonicalUrl = new URL(currentPath, Astro.site).toString();
---
<!DOCTYPE html>
<html lang={locale} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Isabella Nunes</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={`${title} — Isabella Nunes`} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={locale === 'pt' ? 'pt_BR' : 'en_US'} />
    <link rel="alternate" hreflang={altLocale} href={`/${altLocale}${currentPath}`} />
    <link rel="alternate" hreflang="x-default" href={`/pt${currentPath}`} />
    <ThemeProvider />
    <ViewTransitions />
  </head>
  <body>
    <HamburgerMenu
      client:load
      locale={locale}
      currentPath={currentPath}
      navItems={navItems}
      translations={{ common: t.common }}
    />
    <main class="page-content lg:ml-64">
      <nav aria-label="Breadcrumb" class="container pt-6 pb-2">
        <Breadcrumb items={breadcrumbItems} />
      </nav>
      <slot />
    </main>
  </body>
</html>
